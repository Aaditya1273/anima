# ─── Ethereum Sepolia RPC ────────────────────────────────────────────────────
# Get a free endpoint at https://infura.io or https://alchemy.com
NEXT_PUBLIC_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"

# Also used by contracts/hardhat.config.ts for deployment
SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"

# ─── WalletConnect ───────────────────────────────────────────────────────────
# Free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID="your_walletconnect_project_id"

# ─── Zama FHE Relayer ────────────────────────────────────────────────────────
# Get your API key at https://docs.zama.ai/protocol
# This stays SERVER-SIDE only — proxied through /api/relayer/[chainId]
# NEVER prefix with NEXT_PUBLIC_
ZAMA_API_KEY="your_zama_api_key"

# ─── TokenOps SDK ────────────────────────────────────────────────────────────
# Get your API key at https://tokenops.xyz
TOKENOPS_API_KEY="your_tokenops_api_key"

# ─── Session secret (iron-session / SIWE) ────────────────────────────────────
# Must be at least 32 chars. Generate: openssl rand -base64 48
SESSION_SECRET="replace-with-strong-random-32-plus-char-secret"

# ─── Etherscan (for contract verification) ───────────────────────────────────
ETHERSCAN_API_KEY="your_etherscan_api_key"

# ─── Contract deployment ─────────────────────────────────────────────────────
# Private key of the Sepolia deployer wallet (needs testnet ETH)
# Get testnet ETH: https://faucet.sepolia.dev or https://sepoliafaucet.com
# NEVER commit this value to git
DEPLOYER_PRIVATE_KEY="0x_your_deployer_private_key"
